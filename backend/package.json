{
  "name": "truthlens-backend",
  "version": "2.0.0",
  "description": "TruthLens AI - Backend (Express API + TypeScript AI Engine)",
  "private": true,
  "scripts": {
    "dev": "ts-node -P api-tsconfig.json api/server.ts",
    "build": "tsc -p api-tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint api/src --ext .ts",
    "format": "prettier --write \"api/src/**/*.ts\"",
    "db:migrate": "alembic upgrade head",
    "db:seed": "node dist/scripts/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.1.1",
    "@types/cors": "^2.8.19",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "cheerio": "^1.0.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "pg": "^8.11.2",
    "pino": "^8.15.0",
    "pino-pretty": "^10.2.0",
    "prisma": "^5.1.1",
    "uuid": "^14.0.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^6.5.0",
    "@typescript-eslint/parser": "^6.5.0",
    "eslint": "^8.48.0",
    "prettier": "^3.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vitest": "^0.34.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
