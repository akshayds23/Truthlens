# TruthLens Environment Configuration
# Copy this file to .env and fill in the actual values

# ============================================
# Database Configuration
# ============================================
DB_USER=truthlens
DB_PASSWORD=truthlens_dev
DB_NAME=truthlens
DB_HOST=postgres
DB_PORT=5432

# ============================================
# API Gateway Configuration
# ============================================
NODE_ENV=development
PORT=5000
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# ============================================
# AI Service Configuration
# ============================================
LOG_LEVEL=INFO
VECTOR_STORE_TYPE=chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================
# LLM Provider Keys
# ============================================
# Get these from the respective provider websites
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-key-here
GROQ_API_KEY=your-key-here

# ============================================
# Search Provider Keys
# ============================================
BRAVE_SEARCH_API_KEY=your-brave-key-here
SERPER_API_KEY=your-serper-key-here

# ============================================
# Frontend Configuration
# ============================================
VITE_API_URL=http://localhost:5000
VITE_AI_API_URL=http://localhost:8000

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# Frontend Environment (Vite)
# ============================================
VITE_APP_NAME=TruthLens
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Autonomous Fact-Checking & Evidence Research
VITE_DARK_MODE_ENABLED=true
